GROQ_API_KEY=tu_clave_de_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Login de la app Streamlit (obligatorio — sin esto no se puede entrar)
APP_USER=admin
APP_PASSWORD=cambia_esta_clave

# Notificaciones Telegram + Agente Bot
TELEGRAM_BOT_TOKEN=tu_token_de_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
# IDs de usuarios autorizados para hablar con el bot (separados por coma)
# Escribe /id en el bot para conocer tu ID
TELEGRAM_ALLOWED_USERS=123456789

# Publicación real de anuncios (PublicationAgent). Opcional: si se dejan vacías, usa TELEGRAM_CHAT_ID de arriba.
# TELEGRAM_PUBLISH_CHANNEL_USERNAME (sin @) genera un link público real t.me/usuario/mensaje.
TELEGRAM_PUBLISH_CHAT_ID=
TELEGRAM_PUBLISH_CHANNEL_USERNAME=
# Username del bot (sin @), habilita el botón "Consultar y negociar" en el anuncio publicado
TELEGRAM_BOT_USERNAME=

# Airtable (para guardar autos aptos)
# PAT: ve a airtable.com → Account → Developer Hub → Personal access tokens
# BASE_ID: está en la URL de tu base: airtable.com/appXXXXXXXXXXXXXX
# TABLE_NAME: nombre exacto de la tabla (default: "Autos Aptos")
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=tblXXXXXXXXXXXXXX   # Usar el ID de tabla (de la URL), no el nombre

LANGSMITH_API_KEY=your_langsmith_api_key_here    # tu clave de smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=VentasAutomatizacion

# WhatsApp (CallMeBot - gratis)
# Guarda +34 644 91 07 79 como contacto y envíale "I allow callmebot to send me messages"
# Recibirás tu APIKEY de respuesta (puede tardar hasta un par de minutos)
WHATSAPP_PHONE=+51999888777
WHATSAPP_APIKEY=

# Opcional: APIs externas (para publicación real en el futuro)
FACEBOOK_API_KEY=
MERCADOLIBRE_API_KEY=

